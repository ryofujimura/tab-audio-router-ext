{
  "manifest_version": 3,
  "name": "Tab Audio Router",
  "version": "0.2.1",
  "description": "Choose audio output per video/audio from the right-click menu (setSinkId).",
  "permissions": ["contextMenus", "scripting", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
